#!/usr/bin/env zsh

if [[ "$EUID" -eq 0 && -n "${SUDO_USER:-}" ]]; then
  if [[ ! "$SUDO_USER" =~ ^[a-z_][a-z0-9_-]*[$]?$ ]]; then
    echo "ERROR: Invalid SUDO_USER '$SUDO_USER'." >&2
    exit 1
  fi

  USER_HOME="$(getent passwd "$SUDO_USER" | cut -d: -f6)"
  if [[ -z "$USER_HOME" || "$USER_HOME" == "/" || ! -d "$USER_HOME" ]]; then
    echo "ERROR: Could not resolve a safe home directory for '$SUDO_USER'." >&2
    exit 1
  fi

  export USER_HOME
  export BASE_DIR="$USER_HOME/.local/share/beret"
  export SUDO_USER="${SUDO_USER}"
else
  export USER_HOME="$HOME"
  export BASE_DIR="$HOME/.local/share/beret"
fi

run_installer() {
  local component="$1"
  local script="$2"
  if [[ -f "$script" ]]; then
    echo "Installing $component..."
    source "$script"
    echo "✓ $component installed."
  else
    echo "⚠ No install script found for '$component' ($script)"
  fi
}

run_uninstaller() {
  local component="$1"
  local script="$2"
  if [[ -f "$script" ]]; then
    echo "Uninstalling $component..."
    source "$script"
    echo "✓ $component uninstalled."
  else
    echo "⚠ No uninstall script found for '$component' ($script)"
  fi
}

show_component_picker() {
  local action="$1"
  local components=(
    "rust        Systems language"
    "go          Google's compiled language"
    "python      Scripting and data science"
    "java        OpenJDK 21"
    "lua         Lightweight scripting"
    "clang       C, C++, LLVM toolchain"
    "swift       Apple's open-source language"
    "zed         Fast native code editor"
    "cursor      AI-first VS Code fork"
    "vscode      Microsoft's editor"
    "antigravity AI-native editor"
    "firefox     Mozilla's browser"
    "chromium    Google's open browser"
    "brave       Privacy-focused browser"
    "zen         Firefox fork for privacy"
    "neovim      Text editor in terminal"
    "zellij      Terminal multiplexer"
    "lazygit     Git TUI"
    "lazydocker  Docker TUI"
    "docker      Container runtime"
    "discord     Chat app"
    "spotify     Music streaming"
    "obs         Screen recording"
    "krita       Digital painting"
    "virtualbox  Virtual machines"
    "xournalpp   Handwriting notes"
    "aether      Custom theme creator"
  )

  if ! command -v fzf &>/dev/null; then
    echo "fzf not found. Please install with: sudo dnf install fzf"
    echo "Or specify components directly: beret $action <component> ..."
    return 1
  fi

  source "$BASE_DIR/bin/beret-sub/dialog-helpers.sh"

  local header
  if [[ "$action" == "install" ]]; then
    header="Select components to install (Enter to skip):"
  else
    header="Select components to uninstall (Enter to skip):"
  fi

  local selected
  selected=$(beret_dialog_checklist_from_gum "$header" "${components[@]}")
  if [[ -z "$selected" ]]; then
    return 0
  fi

  echo "$selected" | while IFS= read -r line; do
    local line component
    component=$(echo "$line" | awk '{print $1}')
    if [[ "$action" == "install" ]]; then
      install_component "$component"
    else
      uninstall_component "$component"
    fi
  done
}

install_component() {
  local component="$1"
  local install_dir="$BASE_DIR/install"
  case "$component" in
    rust)        run_installer "Rust"        "$install_dir/terminal/langs/rust.sh" ;;
    go|golang)   run_installer "Go"          "$install_dir/terminal/langs/golang.sh" ;;
    python)      run_installer "Python"      "$install_dir/terminal/langs/python.sh" ;;
    java)        run_installer "Java"        "$install_dir/terminal/langs/java.sh" ;;
    lua)         run_installer "Lua"         "$install_dir/terminal/langs/lua.sh" ;;
    clang*|c++) run_installer "Clang/C++"   "$install_dir/terminal/langs/clang.sh" ;;
    swift)       run_installer "Swift"       "$install_dir/terminal/langs/swift.sh" ;;

    zed)         run_installer "Zed"         "$install_dir/desktop/ide/app-zed.sh" ;;
    cursor)      run_installer "Cursor"      "$install_dir/desktop/ide/app-cursor.sh" ;;
    vscode|code) run_installer "VS Code"     "$install_dir/desktop/ide/app-code.sh" ;;
    antigravity) run_installer "Antigravity" "$install_dir/desktop/ide/app-antigravity.sh" ;;

    firefox)     run_installer "Firefox"     "$install_dir/desktop/browser/app-firefox.sh" ;;
    chromium)    run_installer "Chromium"    "$install_dir/desktop/browser/app-chromium.sh" ;;
    brave)       run_installer "Brave"       "$install_dir/desktop/browser/app-brave.sh" ;;
    zen)         run_installer "Zen"         "$install_dir/desktop/browser/app-zen.sh" ;;

    neovim|nvim) run_installer "Neovim"      "$install_dir/terminal/app-neovim.sh" ;;
    zellij)      run_installer "Zellij"      "$install_dir/terminal/app-zellij.sh" ;;
    lazygit)     run_installer "Lazygit"     "$install_dir/terminal/app-lazygit.sh" ;;
    lazydocker)  run_installer "Lazydocker"  "$install_dir/terminal/app-lazydocker.sh" ;;
    btop)        run_installer "btop"        "$install_dir/terminal/app-btop.sh" ;;
    fastfetch)   run_installer "fastfetch"   "$install_dir/terminal/app-fastfetch.sh" ;;
    gh)          run_installer "GitHub CLI"  "$install_dir/terminal/app-github-cli.sh" ;;
    docker)      run_installer "Docker"      "$install_dir/terminal/docker.sh" ;;

    discord)     run_installer "Discord"     "$install_dir/desktop/app-discord.sh" ;;
    spotify)     run_installer "Spotify"     "$install_dir/desktop/app-spotify.sh" ;;
    obs)         run_installer "OBS"         "$install_dir/desktop/app-obs.sh" ;;
    krita)       run_installer "Krita"       "$install_dir/desktop/app-krita.sh" ;;
    virtualbox)  run_installer "VirtualBox"  "$install_dir/desktop/app-virtualbox.sh" ;;
    xournalpp)   run_installer "Xournal++"   "$install_dir/desktop/app-xournalapp.sh" ;;
    alacritty)   run_installer "Alacritty"   "$install_dir/desktop/app-alacritty.sh" ;;
    ulauncher)   run_installer "Ulauncher"   "$install_dir/desktop/ulauncher.sh" ;;
    aether)      run_installer "Aether"      "$install_dir/desktop/app-aether.sh" ;;

    *)
      echo "Unknown component: '$component'"
      echo ""
      echo "Available:"
      echo "  Languages:   rust, go, python, java, lua, clang, swift"
      echo "  IDEs:        zed, cursor, vscode, antigravity"
      echo "  Browsers:    firefox, chromium, brave, zen"
      echo "  Terminal:    neovim, zellij, lazygit, lazydocker, btop, fastfetch, gh, docker"
      echo "  Apps:        discord, spotify, obs, krita, virtualbox, xournalpp, alacritty, ulauncher, aether"
      ;;
  esac
}

uninstall_component() {
  local component="$1"
  local uninstall_dir="$BASE_DIR/uninstall"
  case "$component" in
    rust)        run_uninstaller "Rust"        "$uninstall_dir/langs/rust.sh" ;;
    go|golang)   run_uninstaller "Go"          "$uninstall_dir/langs/golang.sh" ;;
    python)      run_uninstaller "Python"      "$uninstall_dir/langs/python.sh" ;;
    java)        run_uninstaller "Java"        "$uninstall_dir/langs/java.sh" ;;
    lua)         run_uninstaller "Lua"         "$uninstall_dir/langs/lua.sh" ;;
    clang*|c++)  run_uninstaller "Clang/C++"   "$uninstall_dir/langs/clang.sh" ;;
    swift)       run_uninstaller "Swift"       "$uninstall_dir/langs/swift.sh" ;;

    zed)         run_uninstaller "Zed"         "$uninstall_dir/desktop/zed.sh" ;;
    cursor)      run_uninstaller "Cursor"      "$uninstall_dir/desktop/cursor.sh" ;;
    vscode|code) run_uninstaller "VS Code"     "$uninstall_dir/desktop/code.sh" ;;
    antigravity) run_uninstaller "Antigravity" "$uninstall_dir/desktop/antigravity.sh" ;;

    firefox)     run_uninstaller "Firefox"     "$uninstall_dir/desktop/firefox.sh" ;;
    chromium)    run_uninstaller "Chromium"    "$uninstall_dir/desktop/chromium.sh" ;;
    brave)       run_uninstaller "Brave"       "$uninstall_dir/desktop/brave.sh" ;;
    zen)         run_uninstaller "Zen"         "$uninstall_dir/desktop/zen.sh" ;;

    neovim|nvim) run_uninstaller "Neovim"      "$uninstall_dir/terminal/neovim.sh" ;;
    zellij)      run_uninstaller "Zellij"      "$uninstall_dir/terminal/zellij.sh" ;;
    lazygit)     run_uninstaller "Lazygit"     "$uninstall_dir/terminal/lazygit.sh" ;;
    lazydocker)  run_uninstaller "Lazydocker"  "$uninstall_dir/terminal/lazydocker.sh" ;;
    btop)        run_uninstaller "btop"        "$uninstall_dir/terminal/btop.sh" ;;
    fastfetch)   run_uninstaller "fastfetch"   "$uninstall_dir/terminal/fastfetch.sh" ;;
    gh)          run_uninstaller "GitHub CLI"  "$uninstall_dir/terminal/gh.sh" ;;
    docker)      run_uninstaller "Docker"      "$uninstall_dir/terminal/docker.sh" ;;

    discord)     run_uninstaller "Discord"     "$uninstall_dir/desktop/discord.sh" ;;
    spotify)     run_uninstaller "Spotify"     "$uninstall_dir/desktop/spotify.sh" ;;
    obs)         run_uninstaller "OBS"         "$uninstall_dir/desktop/obs.sh" ;;
    krita)       run_uninstaller "Krita"       "$uninstall_dir/desktop/krita.sh" ;;
    virtualbox)  run_uninstaller "VirtualBox"  "$uninstall_dir/desktop/virtualbox.sh" ;;
    xournalpp)   run_uninstaller "Xournal++"   "$uninstall_dir/desktop/xournalpp.sh" ;;
    alacritty)   run_uninstaller "Alacritty"   "$uninstall_dir/desktop/alacritty.sh" ;;
    ulauncher)   run_uninstaller "Ulauncher"   "$uninstall_dir/desktop/ulauncher.sh" ;;
    aether)      run_uninstaller "Aether"      "$uninstall_dir/desktop/aether.sh" ;;

    *)
      echo "Unknown component: '$component'"
      echo ""
      echo "Available:"
      echo "  Languages:   rust, go, python, java, lua, clang, swift"
      echo "  IDEs:        zed, cursor, vscode, antigravity"
      echo "  Browsers:    firefox, chromium, brave, zen"
      echo "  Terminal:    neovim, zellij, lazygit, lazydocker, btop, fastfetch, gh, docker"
      echo "  Apps:        discord, spotify, obs, krita, virtualbox, xournalpp, alacritty, ulauncher, aether"
      ;;
  esac
}

show_help() {
  echo "Beret — Fedora KDE Setup Utility"
  echo ""
  echo "Usage:"
  echo "  beret                              Interactive menu"
  echo "  beret install [component ...]      Install components (no args = picker)"
  echo "  beret uninstall [component ...]    Uninstall components (no args = picker)"
  echo "  beret theme [name]                 Switch theme (or interactive picker)"
  echo "  beret font [name]                  Switch font (or interactive picker)"
  echo "  beret font-size [size]             Set terminal font size"
  echo "  beret aether                       Create a custom theme via Aether GUI"
  echo "  beret update [component ...]       Update applications"
  echo "  beret help                         Show this help"
  echo ""
  echo "Components:"
  echo "  Languages:   rust, go, python, java, lua, clang, swift"
  echo "  IDEs:        zed, cursor, vscode, antigravity"
  echo "  Browsers:    firefox, chromium, brave, zen"
  echo "  Terminal:    neovim, zellij, lazygit, lazydocker, btop, fastfetch, gh, docker"
  echo "  Apps:        discord, spotify, obs, krita, virtualbox, xournalpp, alacritty, ulauncher, aether"
  echo ""
  echo "Examples:"
  echo "  beret install zed rust go"
  echo "  beret uninstall firefox"
  echo "  beret theme tokyo-night"
}

update_component() {
  local component="$1"
  install_component "$component"
}

# ── main ─────────────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
  source "$BASE_DIR/bin/beret-sub/header.sh"
  source "$BASE_DIR/bin/beret-sub/menu.sh"
  exit 0
fi

COMMAND="$1"
shift || true

case "$COMMAND" in
  install|uninstall|update)
    if [[ "$EUID" -ne 0 ]]; then
      exec sudo zsh "$0" "$COMMAND" "$@"
    fi
    ;&
esac

case "$COMMAND" in
  install)
    if [[ $# -eq 0 ]]; then
      show_component_picker "install"
    else
      for component in "$@"; do
        install_component "$component"
      done
    fi
    ;;
  uninstall)
    if [[ $# -eq 0 ]]; then
      show_component_picker "uninstall"
    else
      for component in "$@"; do
        uninstall_component "$component"
      done
    fi
    ;;
  theme)
    if [[ $# -eq 0 ]]; then
      source "$BASE_DIR/bin/beret-sub/theme.sh"
    else
      "$BASE_DIR/bin/beret-theme" "$1"
    fi
    ;;
  font)
    if [[ $# -eq 0 ]]; then
      source "$BASE_DIR/bin/beret-sub/font.sh"
    else
      source "$BASE_DIR/bin/beret-sub/font.sh" "$1"
    fi
    ;;
  font-size)
    if [[ $# -eq 0 ]]; then
      source "$BASE_DIR/bin/beret-sub/font-size.sh"
    else
      sed -i "s/^size = .*$/size = $1/g" ~/.config/alacritty/font-size.toml 2>/dev/null || \
        echo "Warning: font-size.toml not found"
      vs_settings="$HOME/.config/Code/User/settings.json"
      if [[ -f "$vs_settings" ]]; then
        sed -i "s/\"editor.fontSize\": [0-9]*/\"editor.fontSize\": $1/g" "$vs_settings"
        sed -i "s/\"terminal.integrated.fontSize\": [0-9]*/\"terminal.integrated.fontSize\": $1/g" "$vs_settings"
      fi
      echo "Font size set to $1"
    fi
    ;;
  update)
    if [[ $# -eq 0 ]]; then
      source "$BASE_DIR/bin/beret-sub/update.sh"
    else
      for component in "$@"; do
        if [[ "$component" == "beret" ]]; then
          cd "$BASE_DIR" && git pull && cd - >/dev/null 2>&1 || true
        else
          update_component "$component"
        fi
      done
    fi
    ;;
  aether)
    AETHER_BIN="$HOME/.local/share/aether/aether"
    if [[ ! -x "$AETHER_BIN" ]]; then
      echo "Aether is not installed."
      echo "Run 'beret install aether' to install it."
      exit 1
    fi
    echo "Launching Aether theme creator..."
    echo "Design your color scheme in the GUI, then close it to continue."
    "$AETHER_BIN"
    echo ""
    echo "Aether closed. Converting palette to Beret themes..."
    if [[ -f "$BASE_DIR/bin/beret-aether-bridge" ]]; then
      source "$BASE_DIR/bin/beret-aether-bridge"
    else
      beret-aether-bridge
    fi
    ;;
  help|-h|--help)
    show_help
    ;;
  *)
    echo "Unknown command: '$COMMAND'"
    echo "Run 'beret help' to see usage."
    exit 1
    ;;
esac
