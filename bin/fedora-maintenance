#!/usr/bin/env zsh
# Usage: fedora-maintenance

echo "Cleaning orphaned RPM packages..."
sudo dnf autoremove -y
sudo dnf clean all

echo "Cleaning unused Flatpaks..."
flatpak uninstall --unused -y

echo "Cleaning KDE thumbnail cache..."
rm -rf ~/.cache/thumbnails/*

echo "Migrating Alacritty config if YAML still exists..."
if [[ -f ~/.config/alacritty/alacritty.yml ]]; then
    alacritty migrate -c ~/.config/alacritty/alacritty.yml 2>/dev/null || true
fi

echo "Maintenance complete!"
